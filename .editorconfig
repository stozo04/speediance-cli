root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Go uses tabs (gofmt). Don't let editors expand them.
[*.go]
indent_style = tab

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false

# Golden fixtures are byte-exact — leave them untouched.
[testdata/golden/**]
insert_final_newline = false
trim_trailing_whitespace = false
