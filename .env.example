# Speediance credentials (preferred over config.json for agents/headless use)
SPEEDIANCE_EMAIL=you@example.com
SPEEDIANCE_PASSWORD=your-speediance-password
SPEEDIANCE_REGION=Global

# Device type. 1 = Gym Monster (v1).
# NOTE: this CLI is built and tested ONLY for Gym Monster 1. A Gym Monster 2
# exists and may use a different device type and exercise ids - UNTESTED.
SPEEDIANCE_DEVICE_TYPE=1
